{
  "name": "file-explorer",
  "private": true,
  "version": "1.0.0",
  "description": "Production-level File Explorer Desktop Application",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"cross-env BROWSER=none vite\" \"cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.fileexplorer.app",
    "productName": "File Explorer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.2"
  }
}
